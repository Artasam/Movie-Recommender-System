# ── CineMatch Frontend — Environment Variables ──────────────────
# Copy this to .env and fill in values.

# Backend API URL.
# If empty, the frontend will use relative paths (e.g. /api/...)
# In development, Vite will proxy /api to localhost:8000 automatically.
# In production on Vercel, the vercel.json rewrite will proxy /api to the backend.
# VITE_API_BASE_URL=
