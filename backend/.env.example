# ── Movie Recommender API — Environment Variables ────────────────
# Copy this file to .env and fill in real values.

# TMDB API key — required for fetching movie posters
# Get one free at https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# Comma-separated allowed origins for CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Path to the directory containing movies.pkl and similarity.pkl
# Defaults to the project root (parent of backend/)
# DATA_DIR=..

# Enable debug mode (exposes error details in responses)
DEBUG=false

# Server host and port
HOST=0.0.0.0
PORT=8000
